  <Architecture>
    <Pattern>MVC (Model-View-Controller) with API-first approach</Pattern>
    <Database>SQL Server with Entity Framework Core ORM</Database>
    <API>RESTful API with JSON responses</API>
    <Frontend>Vanilla JavaScript with SPA-like navigation</Frontend>
    <Authentication>Custom token-based authentication</Authentication>
    <CORS>Enabled for cross-origin requests</CORS>
    <StaticFiles>Served from wwwroot directory</StaticFiles>
  </Architecture>

  <KeyFeatures>
    <Feature>User registration and authentication</Feature>
    <Feature>Pet listing and adoption system</Feature>
    <Feature>E-commerce shop for pet products</Feature>
    <Feature>Shopping cart and checkout</Feature>
    <Feature>Order history for users</Feature>
    <Feature>Admin panel for content management</Feature>
    <Feature>Adoption request management with Accept/Reject functionality</Feature>
    <Feature>User adoption requests tracking</Feature>
    <Feature>User profiles</Feature>
    <Feature>Favorites/wishlist functionality</Feature>
    <Feature>Area-based search</Feature>
    <Feature>Real-time order status updates</Feature>
    <Feature>Responsive design for mobile and desktop</Feature>
  </KeyFeatures>

  <DatabaseSchema>
    <Table name="Users">
      <Columns>UserId, FirstName, LastName, Email, Password, Phone, City, Area, Pincode, Role, Avatar, IsVerified, CreatedAt</Columns>
      <Relationships>One-to-Many with Pets, Products, Orders, AdoptionRequests</Relationships>
    </Table>
    
    <Table name="Pets">
      <Columns>PetId, Name, Type, Breed, Age, Gender, Description, ImageUrl, OwnerId, Status, CreatedAt</Columns>
      <Relationships>Many-to-One with User, One-to-Many with PetImages, Vaccinations, AdoptionRequests, Reviews, Favorites</Relationships>
    </Table>
    
    <Table name="Products">
      <Columns>ProductId, Name, Category, Description, Price, Stock, PetType, SellerId, CreatedAt</Columns>
      <Relationships>Many-to-One with User, One-to-Many with ProductImages, OrderItems, Reviews</Relationships>
    </Table>
    
    <Table name="Orders">
      <Columns>OrderId, UserId, FullName, Phone, Email, Address, City, Pincode, PaymentMethod, PaymentStatus, TotalAmount, OrderDate, Status</Columns>
      <Relationships>Many-to-One with User, One-to-Many with OrderItems</Relationships>
    </Table>
    
    <Table name="OrderItems">
      <Columns>OrderItemId, OrderId, ProductId, Quantity, Price</Columns>
      <Relationships>Many-to-One with Order, Many-to-One with Product</Relationships>
    </Table>
    
    <Table name="AdoptionRequests">
      <Columns>RequestId, PetId, AdopterId, Message, Status, CreatedAt</Columns>
      <Relationships>Many-to-One with Pet, Many-to-One with User (as Adopter)</Relationships>
    </Table>
    
    <Table name="Areas">
      <Columns>AreaId, Name, City</Columns>
    </Table>
    
    <Table name="Reviews">
      <Columns>ReviewId, PetId, ProductId, UserId, Rating, Comment, CreatedAt</Columns>
    </Table>
    
    <Table name="Favorites">
      <Columns>FavoriteId, UserId, PetId, CreatedAt</Columns>
    </Table>
    
    <Table name="Messages">
      <Columns>MessageId, SenderId, ReceiverId, Content, IsRead, CreatedAt</Columns>
    </Table>
    
    <Table name="Vaccinations">
      <Columns>VaccinationId, PetId, VaccineName, Date, NextDue</Columns>
    </Table>
    
    <Table name="PetImages">
      <Columns>PetImageId, PetId, ImageUrl, IsPrimary</Columns>
    </Table>
    
    <Table name="ProductImages">
      <Columns>ProductImageId, ProductId, ImageUrl, IsPrimary</Columns>
    </Table>
  </DatabaseSchema>
</Project>
