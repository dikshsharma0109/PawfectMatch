      <Page name="index.html" type="Home" />
      <Page name="login.html" type="Authentication" />
      <Page name="register.html" type="Authentication" />
      <Page name="dashboard.html" type="User Dashboard" />
      <Page name="admin.html" type="Admin Panel" />
      <Page name="pet-listing.html" type="Pet Listing" />
      <Page name="pet-details.html" type="Pet Details" />
      <Page name="add-pet.html" type="Pet Management" />
      <Page name="shop.html" type="E-commerce" />
      <Page name="cart.html" type="E-commerce" />
      <Page name="checkout.html" type="E-commerce" />
      <Page name="checkout-form.html" type="E-commerce" />
      <Page name="success.html" type="E-commerce" />
      <Page name="orders.html" type="User Orders - Order History" />
      <Page name="adoption-requests.html" type="User Adoption Requests" />
      <Page name="profile.html" type="User Profile" />
      <Page name="contact.html" type="Contact" />
      <Page name="add-product.html" type="Product Management" />
    </Pages>

